{
  "name": "onair-wyrmgrid",
  "version": "0.2.0",
  "private": true,
  "description": "A modular operations and intelligence platform for OnAir Airline Manager.",
  "license": "MIT",
  "workspaces": [
    "apps/desktop"
  ],
  "scripts": {
    "build": "npm run build --workspace @wyrmgrid/desktop",
    "check": "npm run check --workspace @wyrmgrid/desktop",
    "dev": "npm run tauri --workspace @wyrmgrid/desktop -- dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "atlas:regions": "node scripts/prepare-atlas-regions.mjs",
    "provider:prepare": "node scripts/prepare-simulator-provider.mjs",
    "test:tooling": "node --test scripts/*.test.mjs",
    "tauri": "npm run tauri --workspace @wyrmgrid/desktop --"
  },
  "devDependencies": {
    "prettier": "3.9.5",
    "prettier-plugin-svelte": "4.1.1"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  }
}
