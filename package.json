{
  "name": "onair-wyrmgrid",
  "version": "0.2.0",
  "private": true,
  "description": "A modular operations and intelligence platform for OnAir Airline Manager.",
  "license": "MIT",
  "workspaces": [
    "apps/desktop"
  ],
  "scripts": {
    "build": "npm run build --workspace @wyrmgrid/desktop",
    "check": "npm run check --workspace @wyrmgrid/desktop",
    "dev": "npm run tauri --workspace @wyrmgrid/desktop -- dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ai:task": "node scripts/run-optional-ai-task.mjs",
    "ai:release-curation": "node scripts/run-optional-ai-task.mjs --task release-curation-v1",
    "ai:change-impact": "node scripts/run-optional-ai-task.mjs --task change-impact-v1",
    "ai:test-matrix": "node scripts/run-optional-ai-task.mjs --task test-matrix-v1",
    "ai:docs-sync": "node scripts/run-optional-ai-task.mjs --task docs-sync-v1",
    "ai:fixture-variants": "node scripts/run-optional-ai-task.mjs --task fixture-variants-v1",
    "ai:implementation-patch": "node scripts/run-optional-ai-task.mjs --task implementation-patch-v1",
    "ai:failure-triage": "node scripts/run-optional-ai-task.mjs --task failure-triage-v1",
    "ai:contribution:extract": "node scripts/optional-ai-contribution.mjs extract",
    "ai:contribution:prepare": "node scripts/optional-ai-contribution.mjs prepare",
    "ai:contribution:publish": "node scripts/optional-ai-contribution.mjs publish",
    "atlas:regions": "node scripts/prepare-atlas-regions.mjs",
    "provider:prepare": "node scripts/prepare-simulator-provider.mjs",
    "test:tooling": "node --test scripts/*.test.mjs",
    "tauri": "npm run tauri --workspace @wyrmgrid/desktop --"
  },
  "devDependencies": {
    "prettier": "3.9.5",
    "prettier-plugin-svelte": "4.1.1"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  }
}
