{
  "name": "@wyrmgrid/desktop",
  "version": "0.3.1",
  "description": "OnAir WyrmGrid desktop application",
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/prepare-plugin-packages.mjs && node ../../scripts/prepare-simulator-provider.mjs",
    "dev": "vite dev",
    "build": "vite build",
    "postbuild": "node ../../scripts/verify-desktop-key-art.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "tauri:before-build": "node ../../scripts/prepare-plugin-packages.mjs && node ../../scripts/prepare-simulator-provider.mjs --release --build-frontend"
  },
  "license": "MIT",
  "dependencies": {
    "@fluent/bundle": "0.19.1",
    "@sentry/sveltekit": "10.66.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "2.7.2",
    "echarts": "6.1.0",
    "maplibre-gl": "^5.24.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "5.4.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.70.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tauri-apps/cli": "^2",
    "@types/node": "26.1.1",
    "@types/three": "^0.185.1",
    "svelte": "^5.56.6",
    "svelte-check": "^4.7.3",
    "typescript": "~6.0.3",
    "vite": "^7.1.3",
    "vitest": "4.1.10"
  }
}
