{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OnAir WyrmGrid",
  "version": "0.3.1",
  "identifier": "io.github.phobosdthorga.onairwyrmgrid",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run tauri:before-build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OnAir WyrmGrid",
        "width": 1440,
        "height": 900,
        "minWidth": 640,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://*.ingest.sentry.io https://*.ingest.us.sentry.io https://demotiles.maplibre.org; img-src 'self' asset: http://asset.localhost data: blob: https://demotiles.maplibre.org; style-src 'self' 'unsafe-inline'; worker-src blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "appimage", "deb"],
    "resources": {
      "../../../assets/plugin-packages/*.wyrmplugin": "plugin-packages/",
      "extension-developer-kit/": "extension-developer-kit/"
    },
    "windows": {
      "allowDowngrades": false,
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
