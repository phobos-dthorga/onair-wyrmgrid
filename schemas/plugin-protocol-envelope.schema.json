{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wyrmgrid.dev/schemas/plugin-protocol-envelope-v1.json",
  "title": "WyrmGrid plugin protocol envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "sequence", "payload"],
  "properties": {
    "protocol_version": { "const": 1 },
    "sequence": { "type": "integer", "minimum": 1 },
    "payload": {
      "oneOf": [
        { "$ref": "#/$defs/hello" },
        { "$ref": "#/$defs/fleetSnapshot" },
        { "$ref": "#/$defs/simulatorTelemetrySnapshot" },
        { "$ref": "#/$defs/weatherRequest" },
        { "$ref": "#/$defs/shutdown" },
        { "$ref": "#/$defs/ready" },
        { "$ref": "#/$defs/publishMapLayer" },
        { "$ref": "#/$defs/publishWeather" }
      ]
    }
  },
  "$defs": {
    "permission": {
      "enum": [
        "on_air_company_read",
        "on_air_fleet_read",
        "on_air_jobs_read",
        "on_air_finance_read",
        "map_layers_publish",
        "charts_publish",
        "notifications_create",
        "plugin_storage",
        "simulator_telemetry_read",
        "external_network",
        "weather_data_publish"
      ]
    },
    "weatherCapability": {
      "enum": ["airport_reports", "forecast_grid", "radar_tiles"]
    },
    "coordinates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["latitude", "longitude"],
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "source", "observed_at"],
      "properties": {
        "kind": {
          "enum": [
            "on_air_fact",
            "external_fact",
            "external_calculation",
            "calculated",
            "recommendation"
          ]
        },
        "source": { "type": "string", "minLength": 1, "maxLength": 160 },
        "observed_at": { "type": "string", "format": "date-time" }
      }
    },
    "hello": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "host_version", "plugin_id", "granted_permissions"],
      "properties": {
        "type": { "const": "hello" },
        "host_version": { "type": "string", "minLength": 1 },
        "plugin_id": { "type": "string", "minLength": 1 },
        "granted_permissions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/permission" }
        },
        "weather_capabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/weatherCapability" }
        },
        "network_origins": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^https://[^/?#]+/?$" }
        }
      }
    },
    "fleetSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "snapshot"],
      "properties": {
        "type": { "const": "fleet_snapshot" },
        "snapshot": { "type": "object" }
      }
    },
    "simulatorTelemetrySnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "snapshot"],
      "properties": {
        "type": { "const": "simulator_telemetry_snapshot" },
        "snapshot": {
          "$ref": "simulator-telemetry-snapshot-v1.schema.json"
        }
      }
    },
    "weatherGridRequestPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "location"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 96 },
        "location": { "$ref": "#/$defs/coordinates" }
      }
    },
    "weatherTileAddress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zoom", "x", "y"],
      "properties": {
        "zoom": { "type": "integer", "minimum": 0, "maximum": 8 },
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 }
      }
    },
    "weatherQuery": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "stations"],
          "properties": {
            "kind": { "const": "airport_reports" },
            "stations": {
              "type": "array",
              "minItems": 1,
              "maxItems": 10,
              "uniqueItems": true,
              "items": { "type": "string", "pattern": "^[A-Z0-9]{4}$" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "points"],
          "properties": {
            "kind": { "const": "forecast_grid" },
            "points": {
              "type": "array",
              "minItems": 1,
              "maxItems": 512,
              "items": { "$ref": "#/$defs/weatherGridRequestPoint" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "tiles"],
          "properties": {
            "kind": { "const": "radar_tiles" },
            "tiles": {
              "type": "array",
              "minItems": 1,
              "maxItems": 16,
              "items": { "$ref": "#/$defs/weatherTileAddress" }
            },
            "frame_offset": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            }
          }
        }
      ]
    },
    "weatherRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "request"],
      "properties": {
        "type": { "const": "weather_request" },
        "request": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "query"],
          "properties": {
            "id": { "type": "string", "minLength": 1, "maxLength": 96 },
            "query": { "$ref": "#/$defs/weatherQuery" }
          }
        }
      }
    },
    "shutdown": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": { "type": { "const": "shutdown" } }
    },
    "ready": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "plugin_id", "api_version"],
      "properties": {
        "type": { "const": "ready" },
        "plugin_id": { "type": "string", "minLength": 1 },
        "api_version": { "const": 1 }
      }
    },
    "mapPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "location"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 96 },
        "label": { "type": "string", "minLength": 1, "maxLength": 200 },
        "location": { "$ref": "#/$defs/coordinates" }
      }
    },
    "publishMapLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "layer"],
      "properties": {
        "type": { "const": "publish_map_layer" },
        "layer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "title", "points", "provenance"],
          "properties": {
            "id": { "type": "string", "minLength": 1, "maxLength": 96 },
            "title": { "type": "string", "minLength": 1, "maxLength": 120 },
            "points": {
              "type": "array",
              "maxItems": 10000,
              "items": { "$ref": "#/$defs/mapPoint" }
            },
            "provenance": { "$ref": "#/$defs/provenance" }
          }
        }
      }
    },
    "publishWeather": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "request_id", "response"],
      "properties": {
        "type": { "const": "publish_weather" },
        "request_id": { "type": "string", "minLength": 1, "maxLength": 96 },
        "response": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["status", "code"],
              "properties": {
                "status": { "const": "unavailable" },
                "code": {
                  "enum": [
                    "offline",
                    "timed_out",
                    "rate_limited",
                    "provider_unavailable",
                    "invalid_response",
                    "no_data"
                  ]
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["status", "product"],
              "properties": {
                "status": { "const": "complete" },
                "product": {
                  "oneOf": [
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["kind", "snapshot"],
                      "properties": {
                        "kind": { "const": "airport_reports" },
                        "snapshot": {
                          "$ref": "weather-snapshot-v1.schema.json"
                        }
                      }
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["kind", "layer"],
                      "properties": {
                        "kind": { "const": "global_layer" },
                        "layer": {
                          "$ref": "global-weather-layer-v1.schema.json"
                        }
                      }
                    }
                  ]
                }
              }
            }
          ]
        }
      }
    }
  }
}
