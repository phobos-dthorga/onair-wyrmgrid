{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wyrmgrid.dev/schemas/extension-package-manifest-v1.json",
  "title": "WyrmGrid extension package manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "id",
    "version",
    "manifest_path",
    "files"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "kind": { "enum": ["ordinary_plugin"] },
    "id": {
      "type": "string",
      "maxLength": 255,
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?){2,}$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "manifest_path": { "const": "plugin.json" },
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 512,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "size", "sha256"],
        "properties": {
          "path": { "$ref": "#/$defs/packagePath" },
          "size": {
            "type": "integer",
            "minimum": 1,
            "maximum": 16777216
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    }
  },
  "$defs": {
    "packagePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^[A-Za-z0-9._/-]+$"
    }
  }
}
