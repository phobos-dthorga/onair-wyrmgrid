{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wyrmgrid.dev/schemas/plugin-manifest-v1.json",
  "title": "WyrmGrid plugin manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "version", "api_version", "author", "entry_point"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+){2,}$"
    },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+" },
    "api_version": { "const": 1 },
    "author": { "type": "string", "minLength": 1 },
    "entry_point": { "type": "string", "minLength": 1 },
    "permissions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "on_air_company_read",
          "on_air_fleet_read",
          "on_air_jobs_read",
          "on_air_finance_read",
          "map_layers_publish",
          "notifications_create",
          "plugin_storage",
          "simulator_telemetry_read",
          "external_network"
        ]
      }
    }
  }
}
