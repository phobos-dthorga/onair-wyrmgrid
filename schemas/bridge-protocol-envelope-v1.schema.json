{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wyrmgrid.dev/schemas/bridge-protocol-envelope-v1.json",
  "title": "WyrmGrid Bridge protocol envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "sequence", "payload"],
  "properties": {
    "protocol_version": { "const": 1 },
    "sequence": { "type": "integer", "minimum": 1 },
    "payload": {
      "oneOf": [
        { "$ref": "#/$defs/hostHello" },
        { "$ref": "#/$defs/startTelemetry" },
        { "$ref": "#/$defs/shutdown" },
        { "$ref": "#/$defs/providerHello" },
        { "$ref": "#/$defs/providerState" },
        { "$ref": "#/$defs/telemetry" }
      ]
    }
  },
  "$defs": {
    "capability": {
      "enum": [
        "telemetry_read",
        "active_plan_read",
        "flight_plan_load",
        "command_execute"
      ]
    },
    "hostHello": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "host_version",
        "provider_id",
        "requested_capabilities"
      ],
      "properties": {
        "type": { "const": "hello" },
        "host_version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "provider_id": { "type": "string", "minLength": 1, "maxLength": 255 },
        "requested_capabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/capability" }
        }
      }
    },
    "startTelemetry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "maximum_frequency_hz"],
      "properties": {
        "type": { "const": "start_telemetry" },
        "maximum_frequency_hz": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        }
      }
    },
    "shutdown": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": { "type": { "const": "shutdown" } }
    },
    "providerHello": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "provider"],
      "properties": {
        "type": { "const": "hello" },
        "provider": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "name",
            "version",
            "simulator",
            "architecture",
            "capabilities"
          ],
          "properties": {
            "id": { "type": "string", "minLength": 1, "maxLength": 255 },
            "name": { "type": "string", "minLength": 1, "maxLength": 120 },
            "version": { "type": "string", "minLength": 1, "maxLength": 64 },
            "simulator": { "type": "string", "minLength": 1, "maxLength": 96 },
            "simulator_version": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "architecture": {
              "type": "string",
              "minLength": 1,
              "maxLength": 96
            },
            "capabilities": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/capability" }
            }
          }
        }
      }
    },
    "providerState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "state", "code"],
      "properties": {
        "type": { "const": "state" },
        "state": {
          "enum": [
            "starting",
            "waiting_for_simulator",
            "connected",
            "disconnected",
            "stopped",
            "failed",
            "unavailable"
          ]
        },
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96,
          "pattern": "^[a-z0-9][a-z0-9_.-]*$"
        }
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "snapshot"],
      "properties": {
        "type": { "const": "telemetry" },
        "snapshot": { "$ref": "simulator-telemetry-snapshot-v1.schema.json" }
      }
    }
  }
}
