{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wyrmgrid.dev/schemas/audio-provider-envelope-v1.json",
  "title": "WyrmGrid audio provider protocol envelope header",
  "description": "JSON control header only. An audio_packet carries its declared encoded bytes in the separately framed binary body.",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "sequence", "payload"],
  "properties": {
    "protocol_version": { "const": 1 },
    "sequence": { "type": "integer", "minimum": 1 },
    "payload": {
      "oneOf": [
        { "$ref": "#/$defs/hostHello" },
        { "$ref": "#/$defs/enumerateSources" },
        { "$ref": "#/$defs/requestPermission" },
        { "$ref": "#/$defs/synchronizeClock" },
        { "$ref": "#/$defs/startCapture" },
        { "$ref": "#/$defs/stopCapture" },
        { "$ref": "#/$defs/shutdown" },
        { "$ref": "#/$defs/providerHello" },
        { "$ref": "#/$defs/providerState" },
        { "$ref": "#/$defs/sources" },
        { "$ref": "#/$defs/clockSynchronized" },
        { "$ref": "#/$defs/captureStarted" },
        { "$ref": "#/$defs/audioPacket" },
        { "$ref": "#/$defs/level" },
        { "$ref": "#/$defs/captureEvent" },
        { "$ref": "#/$defs/captureStopped" }
      ]
    }
  },
  "$defs": {
    "machineId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "providerId": {
      "type": "string",
      "maxLength": 255,
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?){2,}$"
    },
    "semanticVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "platform": {
      "enum": [
        "windows_x86_64",
        "linux_x86_64",
        "macos_aarch64",
        "macos_x86_64"
      ]
    },
    "capability": {
      "enum": [
        "source_enumeration",
        "permission_requests",
        "encoded_opus_capture",
        "level_metering",
        "hot_plug_notifications",
        "clock_synchronization"
      ]
    },
    "opusProfile": {
      "enum": ["pilot_microphone_v1", "isolated_voice_v1", "mixed_stereo_v1"]
    },
    "trackRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["track_id", "source_id", "profile"],
      "properties": {
        "track_id": { "$ref": "#/$defs/machineId" },
        "source_id": { "$ref": "#/$defs/machineId" },
        "profile": { "$ref": "#/$defs/opusProfile" }
      }
    },
    "startedTrack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "track_id",
        "source_id",
        "profile",
        "provider_start_monotonic_ns"
      ],
      "properties": {
        "track_id": { "$ref": "#/$defs/machineId" },
        "source_id": { "$ref": "#/$defs/machineId" },
        "profile": { "$ref": "#/$defs/opusProfile" },
        "provider_start_monotonic_ns": { "type": "integer", "minimum": 0 }
      }
    },
    "providerDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version", "platform", "capabilities"],
      "properties": {
        "id": { "$ref": "#/$defs/providerId" },
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "version": { "$ref": "#/$defs/semanticVersion" },
        "platform": { "$ref": "#/$defs/platform" },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/capability" }
        }
      }
    },
    "hostHello": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "host_version", "provider_id"],
      "properties": {
        "type": { "const": "hello" },
        "host_version": { "$ref": "#/$defs/semanticVersion" },
        "provider_id": { "$ref": "#/$defs/providerId" }
      }
    },
    "enumerateSources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": { "type": { "const": "enumerate_sources" } }
    },
    "requestPermission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "source_id"],
      "properties": {
        "type": { "const": "request_permission" },
        "source_id": { "$ref": "#/$defs/machineId" }
      }
    },
    "synchronizeClock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "request_id", "host_send_monotonic_ns"],
      "properties": {
        "type": { "const": "synchronize_clock" },
        "request_id": { "type": "integer", "minimum": 1 },
        "host_send_monotonic_ns": { "type": "integer", "minimum": 0 }
      }
    },
    "startCapture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "session_id", "tracks"],
      "properties": {
        "type": { "const": "start_capture" },
        "session_id": { "$ref": "#/$defs/machineId" },
        "tracks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/trackRequest" }
        }
      }
    },
    "stopCapture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "session_id"],
      "properties": {
        "type": { "const": "stop_capture" },
        "session_id": { "$ref": "#/$defs/machineId" }
      }
    },
    "shutdown": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": { "type": { "const": "shutdown" } }
    },
    "providerHello": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "provider"],
      "properties": {
        "type": { "const": "hello" },
        "provider": { "$ref": "#/$defs/providerDescriptor" }
      }
    },
    "providerState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "state", "code"],
      "properties": {
        "type": { "const": "state" },
        "state": {
          "enum": [
            "starting",
            "ready",
            "capturing",
            "unavailable",
            "failed",
            "stopped"
          ]
        },
        "code": { "$ref": "#/$defs/code" }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "revision", "sources"],
      "properties": {
        "type": { "const": "sources" },
        "revision": { "type": "integer", "minimum": 1 },
        "sources": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "audio-source-capability-v1.schema.json" }
        }
      }
    },
    "clockSynchronized": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "request_id",
        "host_send_monotonic_ns",
        "provider_receive_monotonic_ns",
        "provider_send_monotonic_ns"
      ],
      "properties": {
        "type": { "const": "clock_synchronized" },
        "request_id": { "type": "integer", "minimum": 1 },
        "host_send_monotonic_ns": { "type": "integer", "minimum": 0 },
        "provider_receive_monotonic_ns": { "type": "integer", "minimum": 0 },
        "provider_send_monotonic_ns": { "type": "integer", "minimum": 0 }
      }
    },
    "captureStarted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "session_id", "tracks", "provider_monotonic_ns"],
      "properties": {
        "type": { "const": "capture_started" },
        "session_id": { "$ref": "#/$defs/machineId" },
        "tracks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/startedTrack" }
        },
        "provider_monotonic_ns": { "type": "integer", "minimum": 0 }
      }
    },
    "audioPacket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "session_id",
        "track_id",
        "packet_sequence",
        "provider_monotonic_ns",
        "duration_48khz_frames",
        "payload_bytes"
      ],
      "properties": {
        "type": { "const": "audio_packet" },
        "session_id": { "$ref": "#/$defs/machineId" },
        "track_id": { "$ref": "#/$defs/machineId" },
        "packet_sequence": { "type": "integer", "minimum": 1 },
        "provider_monotonic_ns": { "type": "integer", "minimum": 0 },
        "duration_48khz_frames": { "enum": [120, 240, 480, 960, 1920, 2880] },
        "payload_bytes": { "type": "integer", "minimum": 1, "maximum": 16384 }
      }
    },
    "level": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "session_id",
        "track_id",
        "provider_monotonic_ns",
        "peak_millidbfs",
        "clipped"
      ],
      "properties": {
        "type": { "const": "level" },
        "session_id": { "$ref": "#/$defs/machineId" },
        "track_id": { "$ref": "#/$defs/machineId" },
        "provider_monotonic_ns": { "type": "integer", "minimum": 0 },
        "peak_millidbfs": {
          "type": "integer",
          "minimum": -120000,
          "maximum": 0
        },
        "clipped": { "type": "boolean" }
      }
    },
    "captureEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "session_id",
        "provider_monotonic_ns",
        "event",
        "code"
      ],
      "properties": {
        "type": { "const": "capture_event" },
        "session_id": { "$ref": "#/$defs/machineId" },
        "track_id": { "$ref": "#/$defs/machineId" },
        "provider_monotonic_ns": { "type": "integer", "minimum": 0 },
        "event": {
          "enum": [
            "permission_required",
            "permission_denied",
            "source_unavailable",
            "source_changed",
            "gap",
            "dropout",
            "drift",
            "backpressure",
            "encoder_failure"
          ]
        },
        "code": { "$ref": "#/$defs/code" },
        "affected_frames": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2880000
        },
        "drift_parts_per_million": {
          "type": "integer",
          "minimum": -100000,
          "maximum": 100000
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "event": { "enum": ["gap", "dropout", "backpressure"] }
            },
            "required": ["event"]
          },
          "then": {
            "required": ["affected_frames"],
            "not": { "required": ["drift_parts_per_million"] }
          }
        },
        {
          "if": {
            "properties": { "event": { "const": "drift" } },
            "required": ["event"]
          },
          "then": {
            "required": ["drift_parts_per_million"],
            "not": { "required": ["affected_frames"] }
          }
        },
        {
          "if": {
            "properties": {
              "event": {
                "not": {
                  "enum": ["gap", "dropout", "backpressure", "drift"]
                }
              }
            },
            "required": ["event"]
          },
          "then": {
            "not": {
              "anyOf": [
                { "required": ["affected_frames"] },
                { "required": ["drift_parts_per_million"] }
              ]
            }
          }
        }
      ]
    },
    "captureStopped": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "session_id", "provider_monotonic_ns", "reason"],
      "properties": {
        "type": { "const": "capture_stopped" },
        "session_id": { "$ref": "#/$defs/machineId" },
        "provider_monotonic_ns": { "type": "integer", "minimum": 0 },
        "reason": {
          "enum": [
            "user_requested",
            "source_unavailable",
            "permission_denied",
            "provider_failure",
            "encoder_failure"
          ]
        }
      }
    }
  }
}
