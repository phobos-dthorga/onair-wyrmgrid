{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/phobos-dthorga/onair-wyrmgrid/schemas/optional-ai-github-app-config-v1.schema.json",
  "title": "Optional local-AI GitHub App installation configuration version 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "repository",
    "expected_app_slug",
    "app_id",
    "installation_id",
    "private_key_path"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "kind": {
      "const": "optional-ai-github-app-installation"
    },
    "repository": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "expected_app_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 100
    },
    "app_id": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[1-9][0-9]*$"
        },
        {
          "type": "integer",
          "minimum": 1
        }
      ]
    },
    "installation_id": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[1-9][0-9]*$"
        },
        {
          "type": "integer",
          "minimum": 1
        }
      ]
    },
    "private_key_path": {
      "type": "string",
      "minLength": 1
    }
  }
}
