{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/phobos-dthorga/onair-wyrmgrid/schemas/optional-ai-generated-contribution-v1.schema.json",
  "title": "Optional local-AI generated contribution manifest version 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "contribution_id",
    "assistant_id",
    "assistant_display_name",
    "model",
    "task_contract",
    "created_at",
    "base_branch",
    "branch_name",
    "commit_subject",
    "pull_request_title",
    "summary",
    "allowed_paths",
    "packet_sha256",
    "patch_sha256",
    "metrics_sha256",
    "human_review_required",
    "merge_authority"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "kind": {
      "const": "optional-ai-generated-contribution"
    },
    "contribution_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 80
    },
    "assistant_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 80
    },
    "assistant_display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "model": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "task_contract": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 100
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "base_branch": {
      "const": "main"
    },
    "branch_name": {
      "type": "string",
      "pattern": "^assistant/[a-z0-9]+(?:-[a-z0-9]+)*/[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 120
    },
    "commit_subject": {
      "type": "string",
      "minLength": 1,
      "maxLength": 72
    },
    "pull_request_title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9_.@+/-]+/?$"
      }
    },
    "packet_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "patch_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "metrics_sha256": {
      "oneOf": [
        {
          "$ref": "#/$defs/sha256"
        },
        {
          "type": "null"
        }
      ]
    },
    "human_review_required": {
      "const": true
    },
    "merge_authority": {
      "const": false
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
