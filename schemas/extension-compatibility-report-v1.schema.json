{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wyrmgrid.dev/schemas/extension-compatibility-report-v1.json",
  "title": "WyrmGrid Extension Developer Kit compatibility report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool",
    "command",
    "target",
    "status",
    "extension",
    "compatibility",
    "archive_sha256",
    "checks",
    "issues"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "@wyrmgrid/extension-developer-kit" },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
        }
      }
    },
    "command": {
      "enum": ["validate", "package", "test"]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name"],
      "properties": {
        "type": { "enum": ["source", "package"] },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        }
      }
    },
    "status": { "enum": ["passed", "failed"] },
    "extension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "version"],
      "properties": {
        "kind": {
          "enum": [
            "plugin",
            "simulator-provider",
            "audio-provider",
            "audio-codec"
          ]
        },
        "id": {
          "oneOf": [
            {
              "type": "string",
              "maxLength": 255,
              "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?){2,}$"
            },
            { "type": "null" }
          ]
        },
        "version": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
            },
            { "type": "null" }
          ]
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package_schema_version", "manifest_schema", "protocol"],
      "properties": {
        "package_schema_version": { "const": 1 },
        "manifest_schema": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "protocol": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "version": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          }
        }
      }
    },
    "archive_sha256": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        { "type": "null" }
      ]
    },
    "checks": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "summary"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "status": { "enum": ["passed", "failed", "skipped"] },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          }
        }
      }
    },
    "issues": {
      "type": "array",
      "maxItems": 512,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "code", "path", "message"],
        "properties": {
          "severity": { "enum": ["warning", "error"] },
          "code": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          }
        }
      }
    }
  }
}
