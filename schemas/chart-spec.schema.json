{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wyrmgrid.dev/schemas/chart-spec-v1.json",
  "title": "WyrmGrid declarative chart",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "title", "kind", "series", "provenance"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "title": { "type": "string", "minLength": 1, "maxLength": 160 },
    "description": { "type": "string", "maxLength": 500 },
    "kind": { "enum": ["line", "area", "bar"] },
    "category_axis_label": { "type": "string", "maxLength": 80 },
    "value_axis_label": { "type": "string", "maxLength": 80 },
    "unit": { "type": "string", "maxLength": 32 },
    "series": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "points"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 128 },
          "label": { "type": "string", "minLength": 1, "maxLength": 120 },
          "points": {
            "type": "array",
            "minItems": 1,
            "maxItems": 10000,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["category", "value"],
              "properties": {
                "category": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 120
                },
                "value": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "source", "observed_at"],
      "properties": {
        "kind": {
          "enum": [
            "on_air_fact",
            "external_fact",
            "calculated",
            "recommendation"
          ]
        },
        "source": { "type": "string", "minLength": 1, "maxLength": 200 },
        "observed_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
