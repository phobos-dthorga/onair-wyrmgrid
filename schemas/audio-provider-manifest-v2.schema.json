{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wyrmgrid.dev/schemas/audio-provider-manifest-v2.json",
  "title": "WyrmGrid audio capture provider manifest v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "name",
    "version",
    "audio_protocol_version",
    "author",
    "entry_point",
    "platforms",
    "capabilities"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1, "maxLength": 256 },
    "schema_version": { "const": 2 },
    "id": {
      "type": "string",
      "maxLength": 255,
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?){2,}$"
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "audio_protocol_version": { "const": 2 },
    "author": { "type": "string", "minLength": 1, "maxLength": 120 },
    "entry_point": { "type": "string", "minLength": 1 },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "windows_x86_64",
          "linux_x86_64",
          "macos_aarch64",
          "macos_x86_64"
        ]
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "uniqueItems": true,
      "items": {
        "enum": [
          "source_enumeration",
          "permission_requests",
          "pcm_s16le_capture",
          "level_metering",
          "hot_plug_notifications",
          "clock_synchronization"
        ]
      }
    }
  }
}
