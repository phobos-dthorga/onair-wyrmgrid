{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wyrmgrid.dev/schemas/simulator-provider-manifest-v1.json",
  "title": "WyrmGrid simulator provider manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "name",
    "version",
    "bridge_protocol_version",
    "author",
    "entry_point",
    "platforms",
    "simulators",
    "capabilities"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1, "maxLength": 256 },
    "schema_version": { "const": 1 },
    "id": {
      "type": "string",
      "maxLength": 255,
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?){2,}$"
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "bridge_protocol_version": { "const": 1 },
    "author": { "type": "string", "minLength": 1, "maxLength": 120 },
    "entry_point": { "type": "string", "minLength": 1 },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "windows_x86_64",
          "linux_x86_64",
          "macos_aarch64",
          "macos_x86_64"
        ]
      }
    },
    "simulators": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 96,
        "pattern": "^[a-z0-9][a-z0-9_.-]*$"
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "telemetry_read",
          "active_plan_read",
          "flight_plan_load",
          "command_execute"
        ]
      }
    }
  }
}
