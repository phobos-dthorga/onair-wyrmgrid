{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wyrmgrid.org/schemas/language-pack-v1.schema.json",
  "title": "WyrmGrid community language pack v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "locale",
    "name",
    "source_locale",
    "source_catalog_version",
    "direction",
    "messages"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64,
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$",
      "not": { "pattern": "^wyrmgrid-" }
    },
    "locale": {
      "type": "string",
      "minLength": 2,
      "maxLength": 64,
      "pattern": "^(?:[A-Za-z]{2,8}|x)(?:-[A-Za-z0-9]{1,8})*$"
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "author": { "type": "string", "minLength": 1, "maxLength": 80 },
    "source_locale": { "const": "en-AU" },
    "source_catalog_version": { "const": 23 },
    "direction": { "enum": ["left_to_right", "right_to_left"] },
    "messages": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 2048,
      "propertyNames": { "pattern": "^[a-z][a-z0-9-]{2,95}$" },
      "additionalProperties": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2048
      }
    }
  }
}
