{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wyrmgrid.dev/schemas/global-weather-layer-v1.json",
  "title": "WyrmGrid global weather layer",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "title", "data", "provenance"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "$ref": "#/$defs/identifier" },
    "title": { "type": "string", "minLength": 1, "maxLength": 120 },
    "data": {
      "oneOf": [{ "$ref": "#/$defs/grid" }, { "$ref": "#/$defs/rasterTiles" }]
    },
    "provenance": { "$ref": "#/$defs/provenance" }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "coordinates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["latitude", "longitude"],
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "gridPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "location", "condition"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "location": { "$ref": "#/$defs/coordinates" },
        "condition": {
          "enum": [
            "clear",
            "cloud",
            "rain",
            "snow",
            "convective",
            "obscuration",
            "unknown"
          ]
        },
        "temperature_c": { "type": "number", "minimum": -150, "maximum": 100 },
        "precipitation_mm": { "type": "number", "minimum": 0, "maximum": 1000 },
        "cloud_cover_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "wind_direction_degrees": {
          "type": "number",
          "minimum": 0,
          "maximum": 360
        },
        "wind_speed_kt": { "type": "number", "minimum": 0, "maximum": 500 },
        "provider_weather_code": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        }
      }
    },
    "grid": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "points"],
      "properties": {
        "kind": { "const": "grid" },
        "points": {
          "type": "array",
          "minItems": 1,
          "maxItems": 512,
          "items": { "$ref": "#/$defs/gridPoint" }
        }
      }
    },
    "rasterTile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zoom", "x", "y", "png_base64"],
      "properties": {
        "zoom": { "type": "integer", "minimum": 0, "maximum": 8 },
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "png_base64": { "type": "string", "contentEncoding": "base64" },
        "coverage_png_base64": {
          "type": "string",
          "contentEncoding": "base64"
        }
      }
    },
    "rasterTiles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "frame_time", "tiles"],
      "properties": {
        "kind": { "const": "raster_tiles" },
        "frame_time": { "type": "string", "format": "date-time" },
        "tiles": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "$ref": "#/$defs/rasterTile" }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "provider",
        "retrieved_at",
        "transformation_version",
        "freshness"
      ],
      "properties": {
        "kind": { "enum": ["external_fact", "external_calculation"] },
        "provider": { "type": "string", "minLength": 1, "maxLength": 64 },
        "provider_revision": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "generated_at": { "type": "string", "format": "date-time" },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "transformation_version": { "type": "integer", "minimum": 1 },
        "freshness": { "enum": ["current", "stale", "unknown"] }
      }
    }
  }
}
